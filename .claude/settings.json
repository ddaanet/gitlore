{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/plugin-dev/version-guard.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "gitlore@ddaanet": true,
    "onekeys@ddaanet": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ddaanet": {
      "source": {
        "source": "github",
        "repo": "ddaanet/claude-plugins"
      },
      "autoUpdate": true
    }
  },
  "gitlore": {
    "enabled": true,
    "precommitCommand": ".git/gitlore-pre-commit"
  }
}
